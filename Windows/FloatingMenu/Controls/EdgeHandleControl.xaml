    <UserControl x:Class="FloatingMenu.Controls.EdgeHandleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FloatingMenu.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

        <Button HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
                    PreviewMouseLeftButtonDown="EdgeButton_MouseDown"
                    PreviewMouseMove="EdgeButton_MouseMove"
                    PreviewMouseLeftButtonUp="EdgeButton_MouseUp"
                    Style="{DynamicResource NormalButtonStyle}"
                    ToolTip="Maximize Capture Display">
            </Button>
       
    </Grid>
</UserControl>
